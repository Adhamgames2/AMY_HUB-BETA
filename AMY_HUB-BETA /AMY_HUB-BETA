end)

-- [ القلب النابض للسكربت - معالجة السرعة، الطيران، والميزات التلقائية ]
RunService.Heartbeat:Connect(function()
    pcall(function()
        if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end
        local hrp = LP.Character.HumanoidRootPart
        local hum = LP.Character:FindFirstChildOfClass("Humanoid")
        
        -- [ نظام السرعة الإجباري - Physics Speed Bypass ]
        if hum and not Settings.SafeMode and not Settings.RealFly then
            if Settings.EnableSpeed then
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude > 0 then
                    -- بيحسب اتجاه مشي اللاعب ويديله سرعة قوية في نفس الاتجاه مع الحفاظ على الجاذبية
                    hrp.Velocity = Vector3.new(moveDir.X * Settings.WalkSpeed, hrp.Velocity.Y, moveDir.Z * Settings.WalkSpeed)
                end
            end
        end
        
        -- الطيران الحر الحقيقي (Real Fly)
        if Settings.RealFly and not Settings.SafeMode then
            hum.PlatformStand = true
            local bg = hrp:FindFirstChild("FlyBG") or Instance.new("BodyGyro", hrp)
            bg.Name = "FlyBG"
            bg.P = 90000
            bg.MaxTorque = Vector3.new(90000, 90000, 90000)
            bg.CFrame = Camera.CFrame
            
            local bv = hrp:FindFirstChild("FlyBV") or Instance.new("BodyVelocity", hrp)
            bv.Name = "FlyBV"
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.MaxForce = Vector3.new(90000, 90000, 90000)
            
            local moveDir = Vector3.new(0,0,0)
            if ControlKeys.w then moveDir = moveDir + Camera.CFrame.LookVector end
            if ControlKeys.s then moveDir = moveDir - Camera.CFrame.LookVector end
            if ControlKeys.a then moveDir = moveDir - Camera.CFrame.RightVector end
            if ControlKeys.d then moveDir = moveDir + Camera.CFrame.RightVector end
            
            if moveDir.Magnitude > 0 then
                bv.Velocity = moveDir.Unit * Settings.FlySpeed
            else
                bv.Velocity = Vector3.new(0,0,0)
            end
        end

        if Settings.Spinbot and not Settings.SafeMode then 
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(Settings.SpinSpeed), 0) 
        end
        
        if Settings.AirWalkToggle and not Settings.SafeMode and AirPlatform.Parent == workspace.CurrentCamera then
            AirPlatform.Position = Vector3.new(hrp.Position.X, TargetAirWalkY - 3.5, hrp.Position.Z)
            hrp.CFrame = CFrame.new(hrp.Position.X, TargetAirWalkY, hrp.Position.Z)
        end

        -- ميزة الجلوس على رأس الضحية
        if Settings.SittingOnHead and Settings.CurrentTarget and Settings.CurrentTarget.Character then
            local targetHead = Settings.CurrentTarget.Character:FindFirstChild("Head")
            if targetHead then
                hrp.CFrame = targetHead.CFrame * CFrame.new(0, 2, 0)
            end
        end
        
        -- ميزة الجلتشة والطيران بالضحية المستمر
        if Settings.Flinging and Settings.CurrentTarget and Settings.CurrentTarget.Character then
            local thrp = Settings.CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
            if thrp then
                local bav = hrp:FindFirstChild("FlingBAV") or Instance.new("BodyAngularVelocity", hrp)
                bav.Name = "FlingBAV"
                bav.AngularVelocity = Vector3.new(0, 50000, 0)
                bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                hrp.CFrame = thrp.CFrame
            end
        end
    end)
end)

LP.CharacterAdded:Connect(function() 
    Settings.AirWalkToggle = false 
    Settings.RealFly = false
    Settings.SittingOnHead = false
    Settings.Flinging = false
    AirPlatform.Parent = nil 
end)

-- [ نظام الإيمبوت والرادار ]
RunService.RenderStepped:Connect(function()
    local allTargets = GetValidTargets()
    for _, t in pairs(allTargets) do
        pcall(function()
            local char = t.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and char.Humanoid.Health > 0 and Settings.PlayerESP then
                CreateGunSlayerESP(hrp, t.Name, ThemeColor)
            end
        end)
    end
    
    if Settings.Aimbot and Settings.IsAiming and not Settings.SafeMode then
        local targetHead, dist = nil, math.huge
        for _, t in pairs(allTargets) do
            pcall(function()
                local char = t.Character
                local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                if head and char.Humanoid.Health > 0 then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local isVisible = true
                        if Settings.WallCheck then
                            local rayParams = RaycastParams.new()
                            rayParams.FilterDescendantsInstances = {LP.Character, AirPlatform}
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            local rayResult = workspace:Raycast(Camera.CFrame.Position, head.Position - Camera.CFrame.Position, rayParams)
                            if rayResult and not rayResult.Instance:IsDescendantOf(char) then isVisible = false end
                        end
                        if isVisible then
                            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                            local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if distance < dist then dist = distance; targetHead = head.Position end
                        end
                    end
                end
            end)
        end
        if targetHead then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetHead) end
    end
end)
