RunService.RenderStepped:Connect(function()
	local allTargets = GetValidTargets();
	for _, t in pairs(allTargets) do
		pcall(function()
			local FlatIdent_1013A = 0;
			local char;
			local hrp;
			while true do
				if (0 == FlatIdent_1013A) then
					char = t.Character;
					hrp = char:FindFirstChild("HumanoidRootPart");
					FlatIdent_1013A = 1;
				end
				if (FlatIdent_1013A == 1) then
					if (hrp and (char.Humanoid.Health > 0) and Settings.PlayerESP) then
						CreateGunSlayerESP(hrp, t.Name, Settings.EnemyHitboxColor);
					end
					break;
				end
			end
		end);
	end
	if (Settings.Aimbot and Settings.IsAiming) then
		local targetHead, dist = nil, math.huge;
		for _, t in pairs(allTargets) do
			pcall(function()
				local char = t.Character;
				local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart");
				if (head and (char.Humanoid.Health > 0)) then
					local FlatIdent_2E34E = 0;
					local screenPos;
					local onScreen;
					while true do
						if (FlatIdent_2E34E == 0) then
							screenPos, onScreen = Camera:WorldToViewportPoint(head.Position);
							if onScreen then
								local FlatIdent_2A9F7 = 0;
								local isVisible;
								while true do
									if (FlatIdent_2A9F7 == 0) then
										isVisible = true;
										if Settings.WallCheck then
											local rayParams = RaycastParams.new();
											rayParams.FilterDescendantsInstances = {LP.Character,AirPlatform};
											rayParams.FilterType = Enum.RaycastFilterType.Exclude;
											local rayResult = workspace:Raycast(Camera.CFrame.Position, head.Position - Camera.CFrame.Position, rayParams);
											if (rayResult and not rayResult.Instance:IsDescendantOf(char)) then
												isVisible = false;
											end
										end
										FlatIdent_2A9F7 = 1;
									end
									if (FlatIdent_2A9F7 == 1) then
										if isVisible then
											local FlatIdent_6AEED = 0;
											local screenCenter;
											local distance;
											while true do
												if (FlatIdent_6AEED == 0) then
													screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2);
													distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude;
													FlatIdent_6AEED = 1;
												end
												if (FlatIdent_6AEED == 1) then
													if (distance < dist) then
														local FlatIdent_44265 = 0;
														while true do
															if (0 == FlatIdent_44265) then
																dist = distance;
																targetHead = head.Position;
																break;
															end
														end
													end
													break;
												end
											end
										end
										break;
									end
								end
							end
							break;
						end
					end
				end
			end);
		end
		if targetHead then
			Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetHead);
		end
	end
end);
