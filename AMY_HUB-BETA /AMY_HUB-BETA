local function GetRandomName()
    local str = ""
    for i = 1, math.random(15, 25) do 
        str = str .. string.char(math.random(97, 122)) 
    end
    return str
end

local function FindPlayerByString(str)
    if not str or str == "" then return nil end
    str = string.lower(str)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP then
            local playerName = string.lower(p.Name)
            local displayName = string.lower(p.DisplayName)
            if string.sub(playerName, 1, #str) == str or string.sub(displayName, 1, #str) == str then
                return p
            end
        end
    end
    return nil
end

