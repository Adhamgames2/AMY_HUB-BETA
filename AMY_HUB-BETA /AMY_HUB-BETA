RunService.Heartbeat:Connect(function()
	pcall(function()
		local FlatIdent_7DFA5 = 0;
		local hrp;
		local hum;
		while true do
			if (FlatIdent_7DFA5 == 1) then
				hum = LP.Character:FindFirstChildOfClass("Humanoid");
				if hum then
					local FlatIdent_1FC27 = 0;
					while true do
						if (FlatIdent_1FC27 == 0) then
							if (Settings.EnableSpeed and not Settings.SafeMode) then
								hum.WalkSpeed = Settings.WalkSpeed;
							end
							if Settings.EnableJump then
								hum.UseJumpPower = true;
								hum.JumpPower = Settings.JumpPower;
							end
							break;
						end
					end
				end
				FlatIdent_7DFA5 = 2;
			end
			if (FlatIdent_7DFA5 == 2) then
				if (Settings.Spinbot and not Settings.SafeMode) then
					hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(Settings.SpinSpeed), 0);
				end
				if (Settings.AirWalkToggle and not Settings.SafeMode and (AirPlatform.Parent == workspace.CurrentCamera)) then
					local FlatIdent_691EB = 0;
					while true do
						if (FlatIdent_691EB == 0) then
							AirPlatform.Position = Vector3.new(hrp.Position.X, TargetAirWalkY - 3.5, hrp.Position.Z);
							hrp.CFrame = CFrame.new(hrp.Position.X, TargetAirWalkY, hrp.Position.Z);
							break;
						end
					end
				end
				break;
			end
			if (FlatIdent_7DFA5 == 0) then
				if (not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart")) then
					return;
				end
				hrp = LP.Character.HumanoidRootPart;
				FlatIdent_7DFA5 = 1;
			end
		end
	end);
end);
