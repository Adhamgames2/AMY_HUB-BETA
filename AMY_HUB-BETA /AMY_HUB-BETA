local function CreateSlider(page, name, min, max, default, callback)
	local FlatIdent_35A31 = 0;
	local Frame;
	local Label;
	local Bar;
	local Fill;
	local moving;
	while true do
		if (6 == FlatIdent_35A31) then
			Instance.new("UICorner", Bar).CornerRadius = UDim.new(0, 3);
			Fill = Instance.new("Frame", Bar);
			Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0);
			FlatIdent_35A31 = 7;
		end
		if (FlatIdent_35A31 == 1) then
			Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 6);
			Label = Instance.new("TextLabel", Frame);
			Label.Size = UDim2.new(0.5, 0, 0.5, 0);
			FlatIdent_35A31 = 2;
		end
		if (5 == FlatIdent_35A31) then
			Bar.Position = UDim2.new(0.05, 0, 0.65, 0);
			Bar.BackgroundColor3 = Color3.fromRGB(40, 40, 50);
			Bar.Text = "";
			FlatIdent_35A31 = 6;
		end
		if (FlatIdent_35A31 == 2) then
			Label.Position = UDim2.new(0.05, 0, 0, 0);
			Label.Text = name .. " : " .. tostring(default);
			Label.TextColor3 = Color3.fromRGB(230, 230, 230);
			FlatIdent_35A31 = 3;
		end
		if (FlatIdent_35A31 == 4) then
			Label.BackgroundTransparency = 1;
			Bar = Instance.new("TextButton", Frame);
			Bar.Size = UDim2.new(0.9, 0, 0, 6);
			FlatIdent_35A31 = 5;
		end
		if (FlatIdent_35A31 == 3) then
			Label.Font = Enum.Font.Gotham;
			Label.TextSize = 12;
			Label.TextXAlignment = Enum.TextXAlignment.Left;
			FlatIdent_35A31 = 4;
		end
		if (FlatIdent_35A31 == 7) then
			Fill.BackgroundColor3 = Color3.fromRGB(0, 255, 200);
			Instance.new("UICorner", Fill).CornerRadius = UDim.new(0, 3);
			moving = false;
			FlatIdent_35A31 = 8;
		end
		if (FlatIdent_35A31 == 8) then
			Bar.InputBegan:Connect(function(i)
				if (i.UserInputType == Enum.UserInputType.MouseButton1) then
					moving = true;
				end
			end);
			UserInputService.InputEnded:Connect(function(i)
				if (i.UserInputType == Enum.UserInputType.MouseButton1) then
					moving = false;
				end
			end);
			UserInputService.InputChanged:Connect(function(i)
				if (moving and (i.UserInputType == Enum.UserInputType.MouseMovement)) then
					local FlatIdent_6C033 = 0;
					local pct;
					local val;
					while true do
						if (FlatIdent_6C033 == 2) then
							callback(val);
							break;
						end
						if (0 == FlatIdent_6C033) then
							pct = math.clamp((UserInputService:GetMouseLocation().X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1);
							Fill.Size = UDim2.new(pct, 0, 1, 0);
							FlatIdent_6C033 = 1;
						end
						if (FlatIdent_6C033 == 1) then
							val = math.floor(min + ((max - min) * pct));
							Label.Text = name .. " : " .. tostring(val);
							FlatIdent_6C033 = 2;
						end
					end
				end
			end);
			break;
		end
		if (FlatIdent_35A31 == 0) then
			Frame = Instance.new("Frame", page);
			Frame.Size = UDim2.new(1, -10, 0, 48);
			Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 35);
			FlatIdent_35A31 = 1;
		end
	end
end
